# 智谱 GLM 配置
# 敏感值留空，由开发者在各自机器用环境变量注入（pydantic-settings 读取优先级：
# 进程环境变量 > 本 .env 文件 > app/config.py 默认值）
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# 与 Spring Boot 共享的内部调用密钥
# 留空则 Python/Java 两端均使用默认值 change-me-shared-with-springboot（两端一致即可）
# 如需自定义，请在 Python 与 Spring Boot 两侧用环境变量 INTERNAL_KEY 注入相同值
INTERNAL_KEY=

# 推理控制
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_TEMPERATURE=0.2
